# ── Go ────────────────────────────────────────────────────────────────────────
# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Built c-shared artifacts (re-generated by `go build -buildmode=c-shared`)
go-bridge/libbridge.so
go-bridge/libbridge.h

# Test binary and coverage output
*.test
*.out
coverage.html
coverage.txt

# Go module download cache (not needed in repo)
vendor/

# ── Zig ───────────────────────────────────────────────────────────────────────
# Zig build cache and output
zig-engine/.zig-cache/
zig-engine/zig-out/

# ── Test Fixtures ─────────────────────────────────────────────────────────────
# Synthetic fixture is generated at test time — not stored in repo.
# IMPORTANT: never commit real .tfstate files (they may contain secrets/IPs).
zig-engine/testdata/*.tfstate.json
zig-engine/testdata/*.tfstate

# Real Terraform state files (safety net in case someone copies one here)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# ── Terraform ─────────────────────────────────────────────────────────────────
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── OS / Editor ───────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# VSCode
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# ── PlantUML ──────────────────────────────────────────────────────────────────
# Generated PNGs are committed (documentation); intermediate files are not.
# Uncomment the line below if you prefer to generate PNGs on demand and not commit them:
# docs/**/*.png

# ── Misc ──────────────────────────────────────────────────────────────────────
# Temp files
*.tmp
*.bak
*.orig

# Environment secrets (never commit)
.env
.env.*
secrets.yaml
secrets.json
